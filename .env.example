# =============================================================================
# ENGAJAA — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais
# NUNCA commite o arquivo .env com valores reais
#
# AMBIENTES:
#   Local      → Docker Compose (docker compose up -d)
#   Produção   → Railway (configurar no painel de cada service)
# =============================================================================

# ── Ambiente ──────────────────────────────────────────────────────────────────
NODE_ENV=development          # production no Railway

# ── Servidor (engajaa-api) ────────────────────────────────────────────────────
PORT=3002                     # Railway define automaticamente via $PORT

# ── Banco de dados ────────────────────────────────────────────────────────────
# Local:      postgresql://engajaa:engajaa_secret@localhost:5435/engajaa_dev
# Railway:    usar variável $DATABASE_URL injetada pelo plugin PostgreSQL
DATABASE_URL=postgresql://engajaa:engajaa_secret@localhost:5435/engajaa_dev

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local:      redis://localhost:6380
# Railway:    usar variável $REDIS_URL injetada pelo plugin Redis
REDIS_URL=redis://localhost:6380

# ── JWT RS256 ────────────────────────────────────────────────────────────────
# Gerar local:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Copiar conteúdo como string com \n no lugar das quebras de linha
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# ── Criptografia tokens Instagram (exatamente 32 caracteres) ──────────────────
AES_SECRET=sua_chave_aes_256_bits_aqui_32ch

# ── Meta / Instagram App ─────────────────────────────────────────────────────
IG_CLIENT_ID=sua_instagram_app_id
IG_CLIENT_SECRET=seu_instagram_app_secret
# Local:      https://SEU_TUNNEL.trycloudflare.com/instagram/callback
# Produção:   https://SEU_SERVICO.up.railway.app/instagram/callback
IG_REDIRECT_URI=https://SEU_TUNNEL.trycloudflare.com/instagram/callback

# ── Anthropic (Claude API) ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── E-mail ───────────────────────────────────────────────────────────────────
# Local:       SMTP_HOST=maildev  SMTP_PORT=1026
# Produção:    usar Resend ou SendGrid (SMTP_HOST, SMTP_PORT, SMTP_USER, SMTP_PASS)
SMTP_HOST=maildev
SMTP_PORT=1026
# SMTP_USER=
# SMTP_PASS=

# ── CORS — URL do frontend ────────────────────────────────────────────────────
# Local:      http://localhost:5175
# Produção:   https://SEU_FRONTEND.up.railway.app
FRONTEND_URL=http://localhost:5175

# =============================================================================
# FRONTEND (engajaa-web) — apenas para Railway build arg
# Configurar como variável de ambiente no service engajaa-web do Railway
# =============================================================================
# VITE_API_URL=https://SEU_API_SERVICE.up.railway.app
